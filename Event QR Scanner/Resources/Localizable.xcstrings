    "app_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The QR Scanner App is designed for easy and efficient QR code scanning at sports events. Featuring quick scan capabilities, information retrieval, and seamless integration with event management systems."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "QR Scanner App är designad för enkel och effektiv QR-kodsskanning vid sportevenemang. Appen erbjuder snabb skanningsförmåga, informationsåtervinning och sömlös integration med evenemangshanteringssystem."
          }
        }
      }
    },
